{
    "name": "heatmap-demo-app",
    "version": "1.0.0",
    "description": "Static web app that renders a Leaflet heatmap of open crime data.",
    "type": "module",
    "author": "Charles Cozad",
    "license": "ISC",
    "engines": {
        "node": ">=20"
    },
    "scripts": {
        "dev": "vite",
        "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
        "build": "npm run typecheck && vite build",
        "preview": "vite preview",
        "lint": "eslint .",
        "format": "prettier --write ."
    },
    "devDependencies": {
        "@eslint/js": "^9.17.0",
        "@types/leaflet": "^1.9.15",
        "@types/node": "^22.10.5",
        "eslint": "^9.17.0",
        "eslint-config-prettier": "^9.1.0",
        "globals": "^15.14.0",
        "prettier": "^3.4.2",
        "typescript": "^5.7.3",
        "typescript-eslint": "^8.19.1",
        "vite": "^6.0.7"
    }
}
